# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# PostgreSQL (Role B + C — single database)
# Neon: use pooler URL, sslmode=require only (omit channel_binding=require)
DATABASE_URL=postgresql://user:pass@your-project-pooler.region.aws.neon.tech/dbname?sslmode=require

# JWT (Role B)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Redis (Role C)
REDIS_URL=redis://localhost:6379

# LiveKit (Role C)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Embeddings (Role C — OpenAI or Gemini)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_PROVIDER=gemini
EMBEDDING_DIMENSIONS=1536
SEMANTIC_MAX_DISTANCE=0.40

# Payment webhook (Role B)
PAYMENT_WEBHOOK_SECRET=

# Admin seed (Role B — M6, dev/staging only)
ADMIN_SEED_EMAIL=admin@gmail.com
ADMIN_SEED_PASSWORD=12345678
ADMIN_SEED_USERNAME=Platform Admin
