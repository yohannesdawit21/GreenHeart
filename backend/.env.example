# Server
PORT=4000
NODE_ENV=development

# Comma-separated allowed frontend origins (required in production)
# Example: https://your-app.vercel.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Cookie SameSite: lax (local) | none (cross-origin SPA + HTTPS API)
# Defaults to none when NODE_ENV=production
COOKIE_SAME_SITE=lax

# PostgreSQL (Role B + C — single database)
# Neon: use pooler URL, sslmode=require only (omit channel_binding=require)
DATABASE_URL=postgresql://user:pass@your-project-pooler.region.aws.neon.tech/dbname?sslmode=require

# JWT (Role B) — use a long random string in production
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Redis (Role C) — Upstash: rediss://default:token@host:6379
REDIS_URL=redis://localhost:6379

# LiveKit (Role C) — use LiveKit Cloud in production
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Embeddings (Role C — OpenAI or Gemini)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_PROVIDER=gemini
EMBEDDING_DIMENSIONS=1536
SEMANTIC_MAX_DISTANCE=0.40

# Payment webhook (Role B)
PAYMENT_WEBHOOK_SECRET=

# Admin seed — set RUN_ADMIN_SEED=true on first Render deploy, then disable
ADMIN_SEED_EMAIL=admin@gmail.com
ADMIN_SEED_PASSWORD=12345678
ADMIN_SEED_USERNAME=Platform Admin

# Docker / Render entrypoint (optional)
RUN_DB_MIGRATE=true
RUN_ADMIN_SEED=false
