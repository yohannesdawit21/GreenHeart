# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# PostgreSQL (Role B + C — single database)
DATABASE_URL=postgresql://codex:codex@localhost:5432/codex

# JWT (Role B)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Redis (Role C)
REDIS_URL=redis://localhost:6379

# LiveKit (Role C)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Embeddings (Role C — Gemini)
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Payment webhook (Role B)
PAYMENT_WEBHOOK_SECRET=
