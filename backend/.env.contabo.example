# Copy to .env on your Contabo VPS before: docker compose up -d --build
# cp .env.contabo.example .env

# --- Server ---
API_PORT=4000
NODE_ENV=production

# Allow all origins for VPS testing (use specific URLs in production)
CORS_ORIGIN=*

# --- Redis (docker-compose sets REDIS_URL for the api container) ---
REDIS_PASSWORD=change-me-strong-redis-password

# --- Postgres (Neon or any remote Postgres — required) ---
DATABASE_URL=postgresql://user:pass@your-pooler.neon.tech/dbname?sslmode=require

# --- JWT ---
JWT_SECRET=change-me-long-random-string
JWT_EXPIRES_IN=7d

# --- LiveKit (optional until you test video) ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Embeddings (optional until you test Discover AI search) ---
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_PROVIDER=gemini
EMBEDDING_DIMENSIONS=1536

# --- First deploy only ---
RUN_DB_MIGRATE=true
RUN_ADMIN_SEED=true
ADMIN_SEED_EMAIL=admin@gmail.com
ADMIN_SEED_PASSWORD=12345678
ADMIN_SEED_USERNAME=Platform Admin

# After first successful deploy, set RUN_ADMIN_SEED=false and redeploy
